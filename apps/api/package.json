{
  "name": "api",
  "version": "1.0.0",
  "main": "dist/main/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn -r tsconfig-paths/register src/main/server.ts",
    "build": "prisma generate && tsc && tsc-alias",
    "start": "node -r tsconfig-paths/register dist/main/server.js",
    "prisma:migration": "npx prisma migrate deploy && npx prisma db seed"
  },
  "dependencies": {
    "@google/genai": "^2.9.0",
    "@prisma/client": "^6.19.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsyringe": "^4.10.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "prisma": "^6.19.3",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.9.0",
    "typescript": "^5.9.2"
  },
  "prisma": {
    "seed": "ts-node -r tsconfig-paths/register prisma/seed.ts"
  }
}
