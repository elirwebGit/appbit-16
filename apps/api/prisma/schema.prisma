generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Region {
  id      String @id @default(uuid())
  name    String
  state   String
  country String
}

model Formation {
  id          String @id @default(uuid())
  title       String
  description String
  type        String
  provider    String
  regionId    String
}

model Employment {
  id                  String @id @default(uuid())
  regionId            String
  unemploymentRate    Float
  formalEmploymentRate Float
  sector              String
  demographicGroup    String
}