generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Region {
  id         String            @id @default(uuid())
  name       String
  state      String
  country    String
  indicators RegionIndicator[]
}

model Formation {
  id          String @id @default(uuid())
  title       String
  description String
  type        String
  provider    String
  regionId    String
}

model RegionIndicator {
  id                  String @id @default(uuid())
  indicator           String
  value               Float
  peopleConcentration Int
  networkCoverage     String
  source              String
  regionId            String
  region              Region @relation(fields: [regionId], references: [id])
}

model AIAnalysis {
  id        String   @id @default(uuid())
  question  String
  answer    String   @db.Text
  createdAt DateTime @default(now())
}

model Employment {
  id                   String @id @default(uuid())
  regionId             String
  unemploymentRate     Float
  formalEmploymentRate Float
  sector               String
  demographicGroup     String
}
