# ─── Banco de Dados ────────────────────────────────────────────────────────────
# Desenvolvimento local (Docker Compose): use os valores abaixo sem alterar
# Produção (Railway): substitua pela DATABASE_URL gerada no painel do Railway
#   → Serviços > PostgreSQL > Connect > Public URL
DATABASE_URL="postgresql://appbit:appbit123@localhost:5433/appbit_db?schema=public"

# ─── API ───────────────────────────────────────────────────────────────────────
# Porta em que a API escuta localmente
# Em produção, o Railway injeta PORT automaticamente — variável obrigatória no código
PORT=3000

# ─── Google Gemini ─────────────────────────────────────────────────────────────
# Crie sua chave em: https://aistudio.google.com/app/apikey
# Em produção: adicione como variável de ambiente no painel do Railway
# NUNCA comite a chave real — use apenas neste arquivo de exemplo com placeholder
GEMINI_API_KEY="SUA_CHAVE_AQUI"

# ─── CORS ──────────────────────────────────────────────────────────────────────
# URL do frontend em produção (ex: https://seu-app.vercel.app)
# Deixe vazio em desenvolvimento local
CORS_ORIGIN=""
